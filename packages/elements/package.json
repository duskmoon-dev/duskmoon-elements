{
  "name": "@duskmoon-dev/elements",
  "version": "1.0.0",
  "description": "All DuskMoon custom elements in one package",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./register": {
      "types": "./dist/types/register.d.ts",
      "import": "./dist/esm/register.js",
      "require": "./dist/cjs/register.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "bun run clean",
    "build": "bun run build:esm && bun run build:cjs && bun run build:types",
    "build:esm": "bun build ./src/index.ts ./src/register.ts --outdir ./dist/esm --format esm --sourcemap --external @duskmoon-dev/el-base --external @duskmoon-dev/el-button --external @duskmoon-dev/el-card --external @duskmoon-dev/el-input --external @duskmoon-dev/el-markdown --external @duskmoon-dev/el-switch --external @duskmoon-dev/el-alert --external @duskmoon-dev/el-dialog --external @duskmoon-dev/el-badge --external @duskmoon-dev/el-chip --external @duskmoon-dev/el-tooltip --external @duskmoon-dev/el-progress --external @duskmoon-dev/el-form --external @duskmoon-dev/el-slider --external @duskmoon-dev/el-file-upload --external @duskmoon-dev/el-autocomplete --external @duskmoon-dev/el-datepicker --external @duskmoon-dev/el-select --external @duskmoon-dev/el-cascader --external @duskmoon-dev/el-bottom-navigation --external @duskmoon-dev/el-breadcrumbs --external @duskmoon-dev/el-drawer --external @duskmoon-dev/el-menu --external @duskmoon-dev/el-navbar --external @duskmoon-dev/el-pagination --external @duskmoon-dev/el-stepper --external @duskmoon-dev/el-tabs --external @duskmoon-dev/el-accordion --external @duskmoon-dev/el-bottom-sheet --external @duskmoon-dev/el-popover --external @duskmoon-dev/el-table --external @duskmoon-dev/el-markdown-input --external @duskmoon-dev/el-pro-data-grid --external @duskmoon-dev/el-code-block --external @duskmoon-dev/el-form-group --external @duskmoon-dev/el-navigation --external @duskmoon-dev/el-nested-menu --external @duskmoon-dev/el-otp-input --external @duskmoon-dev/el-pin-input --external @duskmoon-dev/el-segment-control --external @duskmoon-dev/el-theme-controller --external @duskmoon-dev/el-time-input --external @duskmoon-dev/el-code-engine --external @duskmoon-dev/el-circle-menu",
    "build:cjs": "bun build ./src/index.ts ./src/register.ts --outdir ./dist/cjs --format cjs --sourcemap --external @duskmoon-dev/el-base --external @duskmoon-dev/el-button --external @duskmoon-dev/el-card --external @duskmoon-dev/el-input --external @duskmoon-dev/el-markdown --external @duskmoon-dev/el-switch --external @duskmoon-dev/el-alert --external @duskmoon-dev/el-dialog --external @duskmoon-dev/el-badge --external @duskmoon-dev/el-chip --external @duskmoon-dev/el-tooltip --external @duskmoon-dev/el-progress --external @duskmoon-dev/el-form --external @duskmoon-dev/el-slider --external @duskmoon-dev/el-file-upload --external @duskmoon-dev/el-autocomplete --external @duskmoon-dev/el-datepicker --external @duskmoon-dev/el-select --external @duskmoon-dev/el-cascader --external @duskmoon-dev/el-bottom-navigation --external @duskmoon-dev/el-breadcrumbs --external @duskmoon-dev/el-drawer --external @duskmoon-dev/el-menu --external @duskmoon-dev/el-navbar --external @duskmoon-dev/el-pagination --external @duskmoon-dev/el-stepper --external @duskmoon-dev/el-tabs --external @duskmoon-dev/el-accordion --external @duskmoon-dev/el-bottom-sheet --external @duskmoon-dev/el-popover --external @duskmoon-dev/el-table --external @duskmoon-dev/el-markdown-input --external @duskmoon-dev/el-pro-data-grid --external @duskmoon-dev/el-code-block --external @duskmoon-dev/el-form-group --external @duskmoon-dev/el-navigation --external @duskmoon-dev/el-nested-menu --external @duskmoon-dev/el-otp-input --external @duskmoon-dev/el-pin-input --external @duskmoon-dev/el-segment-control --external @duskmoon-dev/el-theme-controller --external @duskmoon-dev/el-time-input --external @duskmoon-dev/el-code-engine --external @duskmoon-dev/el-circle-menu",
    "build:types": "tsc --emitDeclarationOnly --outDir ./dist/types",
    "clean": "del-cli dist",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts' '*.json' '*.md'",
    "format:check": "prettier --check 'src/**/*.ts' '*.json' '*.md'",
    "lint": "eslint src",
    "lint:check": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "release": "bun publish",
    "release:dry-run": "bun publish --dry-run"
  },
  "dependencies": {
    "@duskmoon-dev/el-base": "0.11.2",
    "@duskmoon-dev/el-button": "0.11.2",
    "@duskmoon-dev/el-card": "0.11.2",
    "@duskmoon-dev/el-input": "0.11.2",
    "@duskmoon-dev/el-markdown": "0.11.2",
    "@duskmoon-dev/el-switch": "0.11.2",
    "@duskmoon-dev/el-alert": "0.11.2",
    "@duskmoon-dev/el-dialog": "0.11.2",
    "@duskmoon-dev/el-badge": "0.11.2",
    "@duskmoon-dev/el-chip": "0.11.2",
    "@duskmoon-dev/el-tooltip": "0.11.2",
    "@duskmoon-dev/el-progress": "0.11.2",
    "@duskmoon-dev/el-form": "0.11.2",
    "@duskmoon-dev/el-slider": "0.11.2",
    "@duskmoon-dev/el-file-upload": "0.11.2",
    "@duskmoon-dev/el-autocomplete": "0.11.2",
    "@duskmoon-dev/el-datepicker": "0.11.2",
    "@duskmoon-dev/el-select": "0.11.2",
    "@duskmoon-dev/el-cascader": "0.11.2",
    "@duskmoon-dev/el-bottom-navigation": "0.11.2",
    "@duskmoon-dev/el-breadcrumbs": "0.11.2",
    "@duskmoon-dev/el-drawer": "0.11.2",
    "@duskmoon-dev/el-menu": "0.11.2",
    "@duskmoon-dev/el-navbar": "0.11.2",
    "@duskmoon-dev/el-pagination": "0.11.2",
    "@duskmoon-dev/el-stepper": "0.11.2",
    "@duskmoon-dev/el-tabs": "0.11.2",
    "@duskmoon-dev/el-accordion": "0.11.2",
    "@duskmoon-dev/el-bottom-sheet": "0.11.2",
    "@duskmoon-dev/el-popover": "0.11.2",
    "@duskmoon-dev/el-table": "0.11.2",
    "@duskmoon-dev/el-markdown-input": "0.11.2",
    "@duskmoon-dev/el-pro-data-grid": "0.11.2",
    "@duskmoon-dev/el-code-block": "0.11.2",
    "@duskmoon-dev/el-form-group": "1.0.0",
    "@duskmoon-dev/el-navigation": "1.0.0",
    "@duskmoon-dev/el-nested-menu": "1.0.0",
    "@duskmoon-dev/el-otp-input": "1.0.0",
    "@duskmoon-dev/el-pin-input": "1.0.0",
    "@duskmoon-dev/el-segment-control": "1.0.0",
    "@duskmoon-dev/el-theme-controller": "1.0.0",
    "@duskmoon-dev/el-time-input": "1.0.0",
    "@duskmoon-dev/el-code-engine": "1.0.0",
    "@duskmoon-dev/el-circle-menu": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "mermaid": ">=10.0.0"
  },
  "peerDependenciesMeta": {
    "mermaid": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "duskmoon-dev",
    "duskmoon",
    "custom-elements",
    "customelements",
    "web-components",
    "webcomponents",
    "html"
  ]
}
