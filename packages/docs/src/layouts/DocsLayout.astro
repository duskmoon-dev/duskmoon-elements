---
import BaseLayout from './BaseLayout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Nav from '../components/Nav.astro';
import MobileNav from '../components/MobileNav.astro';
import { readFileSync } from 'node:fs';

interface Props {
  title: string;
  description: string;
  currentPath?: string;
}

const { title, description, currentPath = Astro.url.pathname } = Astro.props;
const isCssArt = currentPath.includes('/docs/art-elements');
const pkg = JSON.parse(readFileSync(new URL('../../../base/package.json', import.meta.url), 'utf-8'));
const version = `v${pkg.version}`;
---

<BaseLayout title={title} description={description}>
  <!-- Register all custom elements for demos -->
  <script>
    import '../scripts/register-elements';
  </script>

  <div class="docs-container">
    <header class="docs-header">
      <div class="header-content">
        <a href="/duskmoon-elements/" class="logo">
          <span class="logo-text">DuskMoon Elements</span>
          <span class="version-chip">{version}</span>
        </a>
        <nav class="header-nav">
          <a
            href="/duskmoon-elements/docs/components"
            class:list={['header-nav-link', { active: !isCssArt }]}
          >
            Components
          </a>
          <a
            href="/duskmoon-elements/docs/art-elements/"
            class:list={['header-nav-link', { active: isCssArt }]}
          >
            Art Elements
          </a>
        </nav>
        <div class="header-actions">
          <div class="desktop-only">
            <ThemeToggle />
          </div>
          <a
            href="https://github.com/duskmoon-dev/duskmoon-elements"
            class="github-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub repository"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        </div>
      </div>
    </header>

    <div class="docs-main">
      <aside class="docs-sidebar" id="sidebar">
        <Nav currentPath={currentPath} />
      </aside>

      <main class="docs-content">
        <article class="content-article">
          <slot />
        </article>
      </main>
    </div>

    <MobileNav currentPath={currentPath} />
  </div>
</BaseLayout>

<style>
  .docs-container {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .docs-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-surface);
    border-bottom: 1px solid var(--color-outline, #e0e0e0);
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    gap: 1rem;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
  }

  .header-nav-link {
    padding: 0.375rem 0.875rem;
    border-radius: 6px;
    color: var(--color-on-surface);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    opacity: 0.7;
    transition: opacity 0.15s, background-color 0.15s;
  }

  .header-nav-link:hover {
    opacity: 1;
    background-color: color-mix(in srgb, var(--color-on-surface) 8%, transparent);
  }

  .header-nav-link.active {
    opacity: 1;
    color: var(--color-primary);
    background-color: color-mix(in srgb, var(--color-primary) 10%, transparent);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-on-surface);
    text-decoration: none;
    font-weight: 600;
    font-size: 1.25rem;
  }

  .logo:hover {
    text-decoration: none;
    color: var(--color-primary);
  }

  .version-chip {
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    color: var(--color-primary);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1.4;
    white-space: nowrap;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .github-link {
    color: var(--color-on-surface);
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .github-link:hover {
    opacity: 1;
  }

  .docs-main {
    display: flex;
    flex: 1;
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
  }

  .docs-sidebar {
    width: 280px;
    flex-shrink: 0;
    padding: 1.5rem;
    border-right: 1px solid var(--color-outline, #e0e0e0);
    position: sticky;
    top: 60px;
    height: calc(100vh - 60px);
    overflow-y: auto;
  }

  .docs-content {
    flex: 1;
    min-width: 0;
    padding: 2rem 3rem;
  }

  .content-article {
    max-width: 800px;
  }

  .desktop-only {
    display: block;
  }

  /* Mobile styles */
  @media (max-width: 768px) {
    .docs-sidebar {
      display: none;
    }

    .docs-content {
      padding: 1.5rem;
    }

    .desktop-only {
      display: none;
    }
  }
</style>
